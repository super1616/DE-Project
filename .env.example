# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_SEARCH_KEYWORDS=python,machine learning,aws

# S3 Buckets
S3_BUCKET_RAW=youtube-data-raw
S3_BUCKET_PROCESSED=youtube-data-processed
S3_BUCKET_ARCHIVE=youtube-data-archive

# Glue Configuration
GLUE_JOB_NAME=TransformYouTubeData
GLUE_DATABASE=youtube_database

# Lambda Configuration
LAMBDA_FUNCTION_NAME=YouTubeDataIngestion
LAMBDA_TIMEOUT=300
LAMBDA_MEMORY=512

# QuickSight Configuration
QUICKSIGHT_AWS_ACCOUNT_ID=123456789012
QUICKSIGHT_NAMESPACE=default
